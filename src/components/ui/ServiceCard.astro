---
import Icon from '@ui/Icon.astro';

interface Props {
  title: string;
  description: string;
  iconPath: string;
  iconBoxClass: string;
}

const { title, description, iconPath, iconBoxClass } = Astro.props;
---

<article class="service-card-hover relative bg-white rounded-[16px] p-8 border border-neutral-100 hover:border-curious-blue-200 hover:shadow-[0_12px_32px_rgba(1,151,227,0.08)] hover:-translate-y-1 transition-all duration-300 overflow-hidden fade-up">
  <div class={`w-[52px] h-[52px] rounded-[10px] flex items-center justify-center mb-5 ${iconBoxClass}`} aria-hidden="true">
    <Icon path={iconPath} size={24} />
  </div>
  <h3 class="font-display text-[20px] font-bold text-neutral-900 mb-2">{title}</h3>
  <p class="text-[14.5px] text-neutral-500 leading-[1.65]">{description}</p>
</article>
