---
interface Props {
  text: string;
  color?: 'blue' | 'teal' | 'blue-light';
}

const { text, color = 'blue' } = Astro.props;

const colorClasses = {
  blue:       'text-curious-blue-500',
  teal:       'text-secondary-600',
  'blue-light': 'text-curious-blue-300',
};
---

<p class={`text-[13px] font-semibold tracking-[2px] uppercase mb-3 ${colorClasses[color]}`}>
  {text}
</p>
