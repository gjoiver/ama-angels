---
import IconBox from '@ui/IconBox.astro';

interface Props {
  title: string;
  items: string[];
  iconPath: string;
}

const { title, items, iconPath } = Astro.props;
---

<article class="bg-white rounded-[16px] p-8 border border-neutral-100 flex flex-col gap-6 fade-up">
  <div class="flex flex-col gap-4">
    <IconBox path={iconPath} class="bg-secondary-50 text-secondary-600" size="lg" iconSize={22} />
    <h3 class="font-display text-[19px] font-bold text-neutral-900 leading-snug">{title}</h3>
  </div>
  <ul class="flex flex-col gap-2.5 list-none m-0 p-0">
    {items.map((item) => (
      <li class="flex items-start gap-2.5">
        <div class="flex-shrink-0 w-5 h-5 rounded-full bg-secondary-50 flex items-center justify-center mt-px" aria-hidden="true">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span class="text-[14px] text-neutral-600 leading-[1.6]">{item}</span>
      </li>
    ))}
  </ul>
</article>
