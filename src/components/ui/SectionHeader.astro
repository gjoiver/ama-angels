---
import EyebrowLabel from '@ui/EyebrowLabel.astro';

interface Props {
  eyebrow: string;
  heading: string;
  description?: string;
  align?: 'center' | 'left';
  eyebrowColor?: 'blue' | 'teal' | 'blue-light';
  headingColor?: 'dark' | 'white';
  descriptionColor?: 'muted' | 'white';
  class?: string;
}

const {
  eyebrow,
  heading,
  description,
  align = 'center',
  eyebrowColor = 'blue',
  headingColor = 'dark',
  descriptionColor = 'muted',
  class: className = '',
} = Astro.props;

const alignClass = align === 'center' ? 'flex flex-col items-center text-center' : 'flex flex-col';
const headingColorClass = headingColor === 'white' ? 'text-white' : 'text-neutral-900';
const descColorClass = descriptionColor === 'white' ? 'text-white/60' : 'text-neutral-500';
---

<div class={`${alignClass} mb-14 fade-up ${className}`}>
  <EyebrowLabel text={eyebrow} color={eyebrowColor} />
  <h2 class={`font-display text-[clamp(32px,5vw,44px)] font-bold leading-[1.15] mb-4 ${headingColorClass}`}>
    {heading}
  </h2>
  {description && (
    <p class={`text-[17px] max-w-[600px] leading-[1.7] ${descColorClass}`}>{description}</p>
  )}
</div>
