---
interface Props {
  path: string;
  size?: number;
  class?: string;
  'aria-hidden'?: boolean;
}

const { path, size = 20, class: className = '', 'aria-hidden': ariaHidden = true } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={ariaHidden}
  set:html={path}
/>
