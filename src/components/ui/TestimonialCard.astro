---
interface Props {
  quote: string;
  name: string;
  service: string;
  origin: string;
}

const { quote, name, service, origin } = Astro.props;
const initial = name.charAt(0);
---

<blockquote class="flex flex-col gap-4 bg-white rounded-2xl p-6 border border-neutral-100 shadow-sm">
  <div class="flex gap-1 text-curious-blue-400" aria-hidden="true">
    {Array.from({ length: 5 }).map(() => (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    ))}
  </div>
  <p class="text-[15px] text-neutral-600 leading-[1.75] italic">&ldquo;{quote}&rdquo;</p>
  <footer class="flex items-center gap-3 pt-1 border-t border-neutral-100">
    <!-- Avatar placeholder — reemplazar con foto real -->
    <div
      class="w-10 h-10 rounded-full bg-curious-blue-100 flex items-center justify-center flex-shrink-0"
      aria-hidden="true"
    >
      <span class="text-[13px] font-bold text-curious-blue-600">{initial}</span>
    </div>
    <div>
      <p class="text-[14px] font-semibold text-neutral-800">{name}</p>
      <p class="text-[12px] text-neutral-400">{service} · {origin}</p>
    </div>
  </footer>
</blockquote>
