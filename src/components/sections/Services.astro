---
interface Service {
  icon: string;
  title: string;
  description: string;
  iconClass: string;
}

const services: Service[] = [
  {
    icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
    title: 'Cirugía Plástica y Estética',
    description:
      'Procedimientos quirúrgicos estéticos y reconstructivos realizados por especialistas certificados. Valoración personalizada y acompañamiento en recuperación.',
    iconClass: 'bg-curious-blue-50 text-curious-blue-600',
  },
  {
    icon: `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
    title: 'Consulta Médica Especializada',
    description:
      'Atención en medicina general, especialidades médicas y psiquiatría, tanto presencial como virtual.',
    iconClass: 'bg-secondary-50 text-secondary-600',
  },
  {
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    title: 'Servicios de Salud Complementarios',
    description:
      'Pediatría, optometría, atención psicológica a domicilio, cuidado post-quirúrgico y cuidados paliativos en casa.',
    iconClass: 'bg-curious-blue-50 text-curious-blue-600',
  },
  {
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
    title: 'Salud Materno-Perinatal y Neonatal',
    description:
      'Acompañamiento especializado durante la gestación, posparto, lactancia y cuidado del recién nacido. Seguimiento clínico y educación en salud.',
    iconClass: 'bg-secondary-50 text-secondary-600',
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Planificación Familiar',
    description:
      'Orientación profesional en salud reproductiva, métodos anticonceptivos, fertilidad y toma de decisiones informadas.',
    iconClass: 'bg-[#fef3c7] text-[#d97706]',
  },
  {
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
    title: 'Salud Mental y Bienestar Emocional',
    description:
      'Espacios vivenciales, talleres y experiencias terapéuticas que integran psicología, espiritualidad consciente y medicina tradicional. Especialmente en comunidades rurales.',
    iconClass: 'bg-[#f3e8ff] text-[#9333ea]',
  },
];
---

<section id="servicios" class="bg-neutral-50 py-24">
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-16 fade-up">
      <p class="text-[13px] font-semibold tracking-[2px] uppercase text-curious-blue-500 mb-3">
        Nuestros Servicios
      </p>
      <h2 class="font-display text-[clamp(32px,5vw,44px)] font-bold text-neutral-900 leading-[1.15] mb-4">
        Atención médica integral<br />para toda la familia
      </h2>
      <p class="text-[17px] text-neutral-500 max-w-[560px] leading-[1.7]">
        Ofrecemos una amplia gama de servicios médicos especializados con los más altos estándares
        de calidad y calidez humana.
      </p>
    </div>

    <!-- Grid 6 cards: 3+3 en desktop -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        services.map((service) => (
          <article class="service-card-hover relative bg-white rounded-[16px] p-8 border border-neutral-100 hover:border-curious-blue-200 hover:shadow-[0_12px_32px_rgba(1,151,227,0.08)] hover:-translate-y-1 transition-all duration-300 overflow-hidden fade-up">
            <div
              class={`w-[52px] h-[52px] rounded-[10px] flex items-center justify-center mb-5 ${service.iconClass}`}
              aria-hidden="true"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={service.icon}
              />
            </div>
            <h3 class="font-display text-[20px] font-bold text-neutral-900 mb-2">{service.title}</h3>
            <p class="text-[14.5px] text-neutral-500 leading-[1.65]">{service.description}</p>
          </article>
        ))
      }
    </div>

  </div>
</section>
