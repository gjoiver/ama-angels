---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import SectionHeader from '@ui/SectionHeader.astro';
import ServiceCard from '@ui/ServiceCard.astro';

const lang = getLangFromUrl(Astro.url);
const translation = useTranslations(lang);

const icons = [
  { path: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`, iconBoxClass: 'bg-curious-blue-50 text-curious-blue-600' },
  { path: `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`, iconBoxClass: 'bg-secondary-50 text-secondary-600' },
  { path: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`, iconBoxClass: 'bg-curious-blue-50 text-curious-blue-600' },
  { path: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`, iconBoxClass: 'bg-secondary-50 text-secondary-600' },
  { path: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`, iconBoxClass: 'bg-[#fef3c7] text-[#d97706]' },
  { path: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`, iconBoxClass: 'bg-[#f3e8ff] text-[#9333ea]' },
];

const cards = [1, 2, 3, 4, 5, 6].map((serviceNum, iconIndex) => ({
  title: translation(`services.item${serviceNum}.title` as any),
  description: translation(`services.item${serviceNum}.description` as any),
  iconPath: icons[iconIndex].path,
  iconBoxClass: icons[iconIndex].iconBoxClass,
}));
---

<section id="servicios" class="bg-neutral-50 py-24">
  <div class="max-w-[1200px] mx-auto px-6">

    <SectionHeader
      eyebrow={translation('services.eyebrow')}
      heading={translation('services.heading')}
      description={translation('services.description')}
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map((card) => (
        <ServiceCard
          title={card.title}
          description={card.description}
          iconPath={card.iconPath}
          iconBoxClass={card.iconBoxClass}
        />
      ))}
    </div>

    <p class="mt-10 text-center text-[13px] text-neutral-400 flex items-center justify-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      {translation('services.qualification')}
    </p>

  </div>
</section>
