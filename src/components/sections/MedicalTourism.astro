---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { buildWhatsappUrl } from '@core/constants/contact';
import SectionHeader from '@ui/SectionHeader.astro';
import DifferentiatorCard from '@ui/DifferentiatorCard.astro';
import StepItem from '@ui/StepItem.astro';
import Button from '@ui/Button.astro';

const lang = getLangFromUrl(Astro.url);
const translation = useTranslations(lang);

const differentiatorIcons = [
  `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>`,
  `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
];

const differentiators = [1, 2, 3, 4].map((diffNum, iconIndex) => ({
  iconPath: differentiatorIcons[iconIndex],
  title: translation(`tourism.diff${diffNum}.title` as any),
  description: translation(`tourism.diff${diffNum}.description` as any),
}));

const steps = [1, 2, 3, 4].map((stepNum) => ({
  num: stepNum,
  title: translation(`tourism.step${stepNum}.title` as any),
  description: translation(`tourism.step${stepNum}.description` as any),
}));

const GLOBE_ICON = `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`;
const WA_ICON = `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.37 0-4.567-.68-6.435-1.852l-.45-.29-2.772.929.929-2.772-.29-.45A9.953 9.953 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>`;
---

<section
  id="turismo"
  class="py-24 relative overflow-hidden"
  style="background: linear-gradient(180deg, #EFF9FF 0%, #ffffff 35%);"
>
  <div class="max-w-[1200px] mx-auto px-6">

    <SectionHeader
      eyebrow={translation('tourism.eyebrow')}
      heading={translation('tourism.heading')}
      description={translation('tourism.description')}
    />

    <!-- Differentiators -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16 fade-up">
      {differentiators.map((item) => (
        <DifferentiatorCard
          title={item.title}
          description={item.description}
          iconPath={item.iconPath}
        />
      ))}
    </div>

    <!-- Process + visual -->
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Steps -->
      <div class="fade-up">
        <p class="text-[15px] font-semibold text-neutral-900 mb-6">{translation('tourism.processTitle')}</p>
        <ol class="relative flex flex-col gap-0 list-none m-0 p-0">
          {steps.map((step, i) => (
            <StepItem
              num={step.num}
              title={step.title}
              description={step.description}
              isLast={i === steps.length - 1}
            />
          ))}
        </ol>
      </div>

      <!-- Visual + CTA -->
      <div class="flex flex-col gap-6 fade-up">
        <div
          class="rounded-[20px] overflow-hidden bg-gradient-to-br from-curious-blue-50 to-secondary-50 flex flex-col items-center justify-center gap-4 min-h-[280px] border border-curious-blue-100"
          aria-hidden="true"
        >
          <div class="w-16 h-16 rounded-full bg-white shadow-[0_8px_24px_rgba(1,151,227,0.1)] flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0068AA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={GLOBE_ICON} />
          </div>
          <p class="font-display text-[18px] text-curious-blue-700 text-center leading-snug">
            {translation('tourism.visualTitle')}
          </p>
        </div>

        <Button
          href={buildWhatsappUrl(translation('tourism.whatsappMessage'))}
          variant="primary"
          size="lg"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-fit"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={WA_ICON} />
          {translation('tourism.cta')}
        </Button>
      </div>

    </div>
  </div>
</section>
