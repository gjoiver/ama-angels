---
---

<section id="inicio" class="relative min-h-screen flex items-center pt-[72px] overflow-hidden">
  <!-- Fondo degradado -->
  <div
    class="absolute inset-0 -z-10"
    style="background:
      radial-gradient(ellipse 80% 60% at 10% 20%, rgba(1,151,227,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 80% 80%, rgba(20,184,166,0.05) 0%, transparent 60%),
      linear-gradient(180deg, #EFF9FF 0%, #ffffff 50%);"
    aria-hidden="true"
  ></div>

  <div class="max-w-[1200px] mx-auto px-6 w-full py-20 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Contenido -->
      <div class="fade-up text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-curious-blue-100 text-curious-blue-700 px-4 py-1.5 rounded-full text-[13px] font-semibold mb-6 border border-curious-blue-200">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
          Enfermeras en tu Casa
        </div>

        <h1 class="font-display text-[clamp(40px,5.5vw,60px)] font-extrabold leading-[1.08] text-neutral-900 tracking-[-1.5px] mb-6">
          Cuidado médico<br />en la <span class="hero-highlight">comodidad de tu hogar</span>
        </h1>

        <p class="text-[18px] leading-[1.75] text-neutral-500 mb-10 max-w-[500px] mx-auto lg:mx-0">
          AMA Angels te ofrece enfermeras a domicilio, turismo médico, cirugía plástica y atención
          integral para pacientes nacionales e internacionales. Financiación disponible para todos
          los procedimientos.
        </p>

        <div class="flex flex-wrap justify-center lg:justify-start gap-4">
          <a
            href="#contacto"
            class="inline-flex items-center gap-2 bg-curious-blue-600 text-white px-8 py-[15px] rounded-[10px] text-[16px] font-semibold shadow-[0_4px_16px_rgba(1,151,227,0.25)] hover:bg-curious-blue-700 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(1,151,227,0.35)] transition-all duration-200"
          >
            Agendar Consulta
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center gap-2 bg-white text-curious-blue-600 px-8 py-[15px] rounded-[10px] text-[16px] font-semibold border-2 border-curious-blue-200 hover:border-curious-blue-400 hover:bg-curious-blue-50 hover:-translate-y-0.5 transition-all duration-200"
          >
            Conocer Servicios
          </a>
        </div>
      </div>

      <!-- Visual (oculto en móvil/tablet) -->
      <div
        class="relative hidden lg:flex justify-center items-center fade-up"
        style="animation-delay: 0.2s"
      >
        <!-- Tarjeta principal -->
        <div
          class="w-full max-w-[500px] aspect-[4/3.5] rounded-[24px] flex flex-col items-center justify-center gap-6 relative overflow-hidden shadow-[0_24px_48px_rgba(1,151,227,0.12)]"
          style="background: linear-gradient(135deg, #DEF1FF 0%, #B6E5FF 40%, #ccfbf1 100%);"
        >
          <!-- TODO: reemplazar con ilustración de enfermera/médico profesional -->
          <div class="flex flex-col items-center gap-4 z-10">
            <div class="w-20 h-20 rounded-full bg-white flex items-center justify-center shadow-[0_8px_24px_rgba(0,0,0,0.08)]">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#0083D3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <p class="font-display text-[20px] text-curious-blue-800 text-center leading-snug">
              Atención Médica<br />de Excelencia
            </p>
          </div>
        </div>

        <!-- Badge flotante 1 -->
        <div
          class="absolute top-[15%] -left-[30px] bg-white px-5 py-3.5 rounded-[16px] shadow-[0_8px_32px_rgba(0,0,0,0.1)] flex items-center gap-3"
          style="animation: float 4s ease-in-out infinite;"
          aria-hidden="true"
        >
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-curious-blue-50 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0083D3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="text-[13px] font-semibold text-neutral-700 leading-tight">Atención 24/7<br/>por WhatsApp</div>
        </div>

        <!-- Badge flotante 2 -->
        <div
          class="absolute bottom-[20%] -right-[20px] bg-white px-5 py-3.5 rounded-[16px] shadow-[0_8px_32px_rgba(0,0,0,0.1)] flex items-center gap-3"
          style="animation: float 4s ease-in-out infinite; animation-delay: 1.5s;"
          aria-hidden="true"
        >
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-curious-blue-50 flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0083D3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <div class="text-[13px] font-semibold text-neutral-700 leading-tight">Enfermera asignada<br/>durante tu recuperación</div>
        </div>
      </div>

    </div>
  </div>
</section>
