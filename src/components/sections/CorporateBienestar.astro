---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { buildWhatsappUrl } from '@core/constants/contact';
import SectionHeader from '@ui/SectionHeader.astro';
import PillarCard from '@ui/PillarCard.astro';
import Button from '@ui/Button.astro';

const lang = getLangFromUrl(Astro.url);
const translation = useTranslations(lang);

const pilarIcons = [
  `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
  `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
];

const pilares = [1, 2, 3].map((pillarNum, iconIndex) => ({
  iconPath: pilarIcons[iconIndex],
  title: translation(`corporate.pillar${pillarNum}.title` as any),
  items: [1, 2, 3, 4].map((itemNum) => translation(`corporate.pillar${pillarNum}.item${itemNum}` as any)),
}));

const CHAT_ICON = `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`;
---

<section id="corporativo" class="bg-white py-24">
  <div class="max-w-[1200px] mx-auto px-6">

    <SectionHeader
      eyebrow={translation('corporate.eyebrow')}
      heading={translation('corporate.heading')}
      description={translation('corporate.description')}
      eyebrowColor="teal"
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {pilares.map((pilar) => (
        <PillarCard
          title={pilar.title}
          items={pilar.items}
          iconPath={pilar.iconPath}
        />
      ))}
    </div>

    <div class="flex justify-center fade-up">
      <Button
        href={buildWhatsappUrl(translation('corporate.whatsappMessage'))}
        variant="secondary"
        size="lg"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={CHAT_ICON} />
        {translation('corporate.cta')}
      </Button>
    </div>

  </div>
</section>
