---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import SectionHeader from '@ui/SectionHeader.astro';
import FeatureRow from '@ui/FeatureRow.astro';

const lang = getLangFromUrl(Astro.url);
const translation = useTranslations(lang);

const featureIcons = [
  `<path d="M16 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/><path d="M2 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/><path d="M7 21h10"/><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>`,
  `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="12" y1="11" x2="16" y2="11"/><line x1="12" y1="16" x2="16" y2="16"/><line x1="8" y1="11" x2="8.01" y2="11"/><line x1="8" y1="16" x2="8.01" y2="16"/>`,
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
];

const features = [1, 2, 3].map((featureNum, iconIndex) => ({
  iconPath: featureIcons[iconIndex],
  title: translation(`legal.feature${featureNum}.title` as any),
  description: translation(`legal.feature${featureNum}.description` as any),
}));
---

<section id="legal" class="bg-neutral-900 relative overflow-hidden py-24">
  <div
    class="absolute -top-[50%] -right-[20%] w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(1,151,227,0.15) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="max-w-[1200px] mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <SectionHeader
        eyebrow={translation('legal.eyebrow')}
        heading={translation('legal.heading')}
        description={translation('legal.description')}
        align="left"
        eyebrowColor="blue-light"
        headingColor="white"
        descriptionColor="white"
        class="mb-0"
      />

      <div class="flex flex-col gap-4 fade-up">
        {features.map((feature) => (
          <FeatureRow
            title={feature.title}
            description={feature.description}
            iconPath={feature.iconPath}
          />
        ))}
      </div>

    </div>
  </div>
</section>
