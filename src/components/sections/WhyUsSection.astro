---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import SectionHeader from '@ui/SectionHeader.astro';
import DifferentiatorCard from '@ui/DifferentiatorCard.astro';

const lang = getLangFromUrl(Astro.url);
const translation = useTranslations(lang);

const diffIcons = [
  `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  `<path d="M16 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/><path d="M2 16l3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1z"/><path d="M7 21h10"/><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>`,
  `<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>`,
];

const differentiators = [1, 2, 3, 4].map((n, i) => ({
  iconPath: diffIcons[i],
  title: translation(`whyUs.diff${n}.title` as any),
  description: translation(`whyUs.diff${n}.description` as any),
}));

const stats = [1, 2, 3, 4].map((n) => ({
  value: translation(`whyUs.stat${n}.value` as any),
  label: translation(`whyUs.stat${n}.label` as any),
}));
---

<section id="por-que-nosotros" class="bg-white py-24">
  <div class="max-w-[1200px] mx-auto px-6">

    <SectionHeader
      eyebrow={translation('whyUs.eyebrow')}
      heading={translation('whyUs.heading')}
      description={translation('whyUs.description')}
    />

    <!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-16 fade-up">
      {stats.map((stat) => (
        <div class="flex flex-col items-center text-center p-6 rounded-2xl bg-curious-blue-50 border border-curious-blue-100">
          <span class="font-display text-[clamp(32px,4vw,44px)] font-extrabold text-curious-blue-600 leading-none mb-1">
            {stat.value}
          </span>
          <span class="text-[13px] text-neutral-500 font-medium">{stat.label}</span>
        </div>
      ))}
    </div>

    <!-- Differentiators -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 fade-up">
      {differentiators.map((item) => (
        <DifferentiatorCard
          title={item.title}
          description={item.description}
          iconPath={item.iconPath}
        />
      ))}
    </div>

  </div>
</section>
