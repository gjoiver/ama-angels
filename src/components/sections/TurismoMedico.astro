---
const stats = [
  { value: '15+', label: 'Países' },
  { value: '24/7', label: 'Soporte' },
  { value: '+5,000', label: 'Pacientes' },
  { value: '100%', label: 'Coordinado' },
] as const;

const steps = [
  {
    num: 1,
    title: 'Contacto y Valoración',
    description:
      'Envíanos tu caso por WhatsApp o formulario. Nuestro equipo médico evalúa y te asesora sin costo.',
  },
  {
    num: 2,
    title: 'Planificación del Viaje',
    description:
      'Coordinamos fechas, hospedaje y traslados. Te recogemos en el aeropuerto y te acompañamos a cada cita.',
  },
  {
    num: 3,
    title: 'Procedimiento y Recuperación',
    description:
      'Atención médica de primer nivel con seguimiento post-quirúrgico en tu alojamiento o clínica.',
  },
  {
    num: 4,
    title: 'Seguimiento Remoto',
    description:
      'Una vez en tu país, mantenemos contacto para control y seguimiento de tu recuperación.',
  },
] as const;

const WHATSAPP_HREF = `https://wa.me/573000000000?text=${encodeURIComponent('Hola, quiero información sobre Turismo Médico')}`;
---

<section
  id="turismo"
  class="py-24 relative overflow-hidden"
  style="background: linear-gradient(180deg, #EFF9FF 0%, #ffffff 35%);"
>
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Header -->
    <div class="flex flex-col items-center text-center mb-14 fade-up">
      <p class="text-[13px] font-semibold tracking-[2px] uppercase text-curious-blue-500 mb-3">
        Para Pacientes Internacionales
      </p>
      <h2 class="font-display text-[clamp(32px,5vw,44px)] font-bold text-neutral-900 leading-[1.15] mb-4">
        Turismo Médico en Colombia
      </h2>
      <p class="text-[17px] text-neutral-500 max-w-[600px] leading-[1.7]">
        Coordinación integral para pacientes que viajan a Colombia por procedimientos médicos.
        Nos encargamos de todo para que solo te preocupes por tu salud.
      </p>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-16 fade-up">
      {
        stats.map((stat) => (
          <div class="flex flex-col items-center gap-1 bg-white rounded-[16px] px-6 py-5 border border-curious-blue-100 shadow-[0_2px_12px_rgba(1,151,227,0.06)]">
            <span class="font-display text-[32px] font-bold text-curious-blue-600 leading-none">
              {stat.value}
            </span>
            <span class="text-[13px] text-neutral-500 font-medium">{stat.label}</span>
          </div>
        ))
      }
    </div>

    <!-- Proceso + visual -->
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Pasos -->
      <div class="fade-up">
        <p class="text-[15px] font-semibold text-neutral-900 mb-6">¿Cómo funciona?</p>

        <!-- Timeline con línea conectora -->
        <ol class="relative flex flex-col gap-0 list-none m-0 p-0">
          {
            steps.map((step, index) => (
              <li class="relative flex items-start gap-5 pb-8 last:pb-0">
                {/* Línea conectora */}
                {index < steps.length - 1 && (
                  <div
                    class="absolute left-[21px] top-11 bottom-0 w-px bg-curious-blue-100"
                    aria-hidden="true"
                  />
                )}

                {/* Número */}
                <div
                  class="relative z-10 flex-shrink-0 w-11 h-11 rounded-full bg-curious-blue-600 flex items-center justify-center font-bold text-[15px] text-white shadow-[0_4px_12px_rgba(1,151,227,0.25)]"
                  aria-hidden="true"
                >
                  {step.num}
                </div>

                {/* Contenido */}
                <div class="flex flex-col gap-1 pt-2">
                  <h3 class="font-bold text-neutral-900 text-[16px]">{step.title}</h3>
                  <p class="text-[14px] text-neutral-500 leading-[1.65]">{step.description}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Visual + CTA -->
      <div class="flex flex-col gap-6 fade-up">
        <!-- Placeholder visual -->
        <div
          class="rounded-[20px] overflow-hidden bg-gradient-to-br from-curious-blue-50 to-secondary-50 flex flex-col items-center justify-center gap-4 min-h-[280px] border border-curious-blue-100"
          aria-hidden="true"
        >
          <!-- TODO: reemplazar con foto real de paciente internacional / ciudad de Colombia -->
          <div class="w-16 h-16 rounded-full bg-white shadow-[0_8px_24px_rgba(1,151,227,0.1)] flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0068AA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <p class="font-display text-[18px] text-curious-blue-700 text-center leading-snug">
            Pacientes de<br />más de 15 países
          </p>
        </div>

        <!-- Descripción adicional -->
        <div class="flex flex-col gap-3">
          {
            [
              { icon: `<polyline points="20 6 9 17 4 12"/>`, text: 'Agendamiento de citas con especialistas certificados' },
              { icon: `<polyline points="20 6 9 17 4 12"/>`, text: 'Transporte aeropuerto · hotel · clínica incluido' },
              { icon: `<polyline points="20 6 9 17 4 12"/>`, text: 'Enfermera de acompañamiento durante toda la estadía' },
              { icon: `<polyline points="20 6 9 17 4 12"/>`, text: 'Seguimiento médico remoto post-procedimiento' },
            ].map((item) => (
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-5 h-5 rounded-full bg-curious-blue-100 flex items-center justify-center">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#0083D3" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                </div>
                <span class="text-[14px] text-neutral-600">{item.text}</span>
              </div>
            ))
          }
        </div>

        <!-- CTA -->
        <a
          href={WHATSAPP_HREF}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 bg-curious-blue-600 text-white px-8 py-4 rounded-[10px] text-[16px] font-semibold shadow-[0_4px_16px_rgba(1,151,227,0.25)] hover:bg-curious-blue-700 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(1,151,227,0.35)] transition-all duration-200 w-full sm:w-fit"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.37 0-4.567-.68-6.435-1.852l-.45-.29-2.772.929.929-2.772-.29-.45A9.953 9.953 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>
          </svg>
          Consultar disponibilidad
        </a>
      </div>

    </div>
  </div>
</section>
