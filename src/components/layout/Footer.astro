---
const currentYear = new Date().getFullYear();

const services = [
  { label: 'Turismo Médico', href: '#turismo' },
  { label: 'Cirugía Plástica', href: '#servicios' },
  { label: 'Consulta Especializada', href: '#servicios' },
  { label: 'Atención Domiciliaria', href: '#servicios' },
] as const;

const info = [
  { label: 'Financiación', href: '#financiacion' },
  { label: 'Política de Privacidad', href: '#' },
  { label: 'Términos y Condiciones', href: '#' },
] as const;
---

<footer class="bg-neutral-900 text-white/70 pt-16 pb-8">
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Grid principal -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-10 mb-12">

      <!-- Marca -->
      <div class="flex flex-col gap-4">
        <a href="#inicio" class="inline-flex">
          <img
            src="/logo-ama-angels.svg"
            alt="AMA ANGELS"
            class="h-14 w-auto"
            width="180"
            height="56"
          />
        </a>
        <p class="text-[14px] leading-[1.7] max-w-[280px]">
          Enfermeras en tu casa. Servicios médicos integrales para pacientes nacionales e
          internacionales.
        </p>
      </div>

      <!-- Servicios -->
      <div>
        <h4 class="text-white font-bold text-[14px] mb-5 uppercase tracking-[1px]">Servicios</h4>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            services.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-[14px] hover:text-curious-blue-300 transition-colors duration-200"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Información -->
      <div>
        <h4 class="text-white font-bold text-[14px] mb-5 uppercase tracking-[1px]">
          Información
        </h4>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {
            info.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-[14px] hover:text-curious-blue-300 transition-colors duration-200"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="text-white font-bold text-[14px] mb-5 uppercase tracking-[1px]">Contacto</h4>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          <li class="flex items-start gap-2.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 text-white/40" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-[14px]">Medellín, Colombia</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-white/40" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+573004534836" class="text-[14px] hover:text-curious-blue-300 transition-colors duration-200">
              +57 300 453 4836
            </a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-white/40" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:salud.encasa.amaangels@gmail.com" class="text-[14px] hover:text-curious-blue-300 transition-colors duration-200">
              salud.encasa.amaangels@gmail.com
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-[13px] text-white/40">
      <p>&copy; {currentYear} AMA ANGELS. Todos los derechos reservados.</p>
      <p>Developed by JG</p>
    </div>

  </div>
</footer>
