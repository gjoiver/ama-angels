---
import { getLangFromUrl, useTranslations } from '@i18n/utils';
import { buildWhatsappUrl } from '@core/constants/contact';
const lang = getLangFromUrl(Astro.url);
const translation = useTranslations(lang);
const navWhatsappUrl = buildWhatsappUrl('Hola, quiero agendar una cita con AMA ANGELS');

const navLinks = [
  { label: translation('nav.services'),  href: '#servicios' },
  { label: translation('nav.tourism'),   href: '#turismo' },
  { label: translation('nav.corporate'), href: '#corporativo' },
  { label: translation('nav.financing'), href: '#financiacion' },
  { label: translation('nav.legal'),     href: '#legal' },
  { label: translation('nav.contact'),   href: '#contacto' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-[100] bg-white/[0.92] backdrop-blur-[20px] border-b border-neutral-100 transition-shadow duration-300"
>
  <div class="max-w-[1200px] mx-auto px-6 flex items-center justify-between h-[72px]">
    <!-- Logo -->
    <a href="#inicio" class="flex items-center">
      <img
        src="/logo-ama-angels.png"
        alt="AMA ANGELS — Enfermeras en tu Casa"
        class="h-12 w-auto object-contain"
        width="160"
        height="48"
      />
    </a>

    <!-- Links desktop -->
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link text-[15px] font-medium text-neutral-600 hover:text-curious-blue-600 transition-colors duration-200">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA desktop -->
    <a
      href={navWhatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center bg-curious-blue-600 text-white px-[22px] py-[10px] rounded-[10px] text-[14px] font-semibold hover:bg-curious-blue-700 hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(1,151,227,0.3)] transition-all duration-200"
    >
      {translation('nav.cta')}
    </a>

    <!-- Hamburger mobile -->
    <button
      id="mobile-toggle"
      class="md:hidden flex items-center justify-center p-2 rounded-md hover:bg-neutral-100 transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#374151"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-translation border-neutral-100 bg-white"
    aria-hidden="true"
  >
    <ul class="flex flex-col px-6 py-4 gap-1 list-none m-0 p-0">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="block py-2 text-[15px] font-medium text-neutral-600 hover:text-curious-blue-600 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-3 pb-1 px-0">
        <a href={navWhatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex bg-curious-blue-600 text-white px-[22px] py-[10px] rounded-[10px] text-[14px] font-semibold">
          {translation('nav.cta')}
        </a>
      </li>
    </ul>
  </div>
</nav>

<script src="../../scripts/navbar.ts"></script>
