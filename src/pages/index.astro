---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@layout/Navbar.astro';
import Footer from '@layout/Footer.astro';
import Hero from '@sections/Hero.astro';
import TestimonialsSection from '@sections/TestimonialsSection.astro';
import WhyUsSection from '@sections/WhyUsSection.astro';
import Services from '@sections/Services.astro';
import MedicalTourism from '@sections/MedicalTourism.astro';
import CorporateBienestar from '@sections/CorporateBienestar.astro';
import FinancingBanner from '@sections/FinancingBanner.astro';
import LegalSection from '@sections/LegalSection.astro';
import FaqSection from '@sections/FaqSection.astro';
import CtaSection from '@sections/CtaSection.astro';
import WhatsAppFloat from '@ui/WhatsAppFloat.astro';
---

<BaseLayout>
  <Navbar />
  <main id="main-content">
    <Hero />
    <TestimonialsSection />
    <WhyUsSection />
    <Services />
    <MedicalTourism />
    <CorporateBienestar />
    <FinancingBanner />
    <LegalSection />
    <FaqSection />
    <CtaSection />
  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
