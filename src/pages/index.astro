---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import TurismoMedico from '../components/sections/TurismoMedico.astro';
import CorporateBienestar from '../components/sections/CorporateBienestar.astro';
import FinancingBanner from '../components/sections/FinancingBanner.astro';
import LegalSection from '../components/sections/LegalSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import WhatsAppFloat from '../components/ui/WhatsAppFloat.astro';
---

<BaseLayout>
  <Navbar />
  <main id="main-content">
    <Hero />
    <Services />
    <TurismoMedico />
    <CorporateBienestar />
    <FinancingBanner />
    <LegalSection />
    <CtaSection />
  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
